{
  "description": "Duplicate os/arch target entries are rejected.",
  "config": {
    "owner": "tooppoo",
    "repo": "rellog",
    "binary": {
      "name": "rellog",
      "pathInArchive": "bin/rellog"
    },
    "versionResolver": {
      "type": "release_version_file",
      "fileName": "VERSION"
    },
    "archive": {
      "format": "tar.gz",
      "nameTemplate": "{repo}_{version}_{target}.tar.gz"
    },
    "checksum": {
      "fileName": "checksums.txt",
      "algorithm": "sha256"
    },
    "targets": [
      { "os": "linux", "arch": "x86_64" },
      { "os": "linux", "arch": "x86_64" }
    ]
  },
  "expectedErrors": [{ "path": "$.targets[1]", "reasonIncludes": "Duplicate target entry." }]
}
