{
  "description": "Version resolvers outside release_version_file and latest_asset are rejected.",
  "config": {
    "owner": "tooppoo",
    "repo": "rellog",
    "binary": {
      "name": "rellog",
      "pathInArchive": "bin/rellog"
    },
    "versionResolver": {
      "type": "redirect_tag"
    },
    "archive": {
      "format": "tar.gz",
      "nameTemplate": "{repo}_{target}.tar.gz"
    },
    "checksum": {
      "fileName": "checksums.txt",
      "algorithm": "sha256"
    },
    "targets": [{ "os": "linux", "arch": "x86_64" }]
  },
  "expectedErrors": [
    { "path": "$.versionResolver.type", "reasonIncludes": "Unsupported version resolver." }
  ]
}
