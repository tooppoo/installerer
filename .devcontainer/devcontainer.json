{
  "name": "installerer-dev",
  "image": "mcr.microsoft.com/devcontainers/base:2.1.11-trixie",
  "workspaceFolder": "/workspaces/installerer",
  "remoteUser": "vscode",
  "runArgs": ["--init"],
  "postCreateCommand": "sh scripts/setup-dev.sh",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers-extra/features/bun:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "EditorConfig.EditorConfig",
        "oven.bun-vscode",
        "skellock.just",
        "oxc.oxc-vscode"
      ],
      "settings": {
        "editor.defaultFormatter": "oxc.oxc-vscode",
        "editor.formatOnSave": true,
        "files.eol": "\n"
      }
    }
  }
}
