{
  "name": "@philomagi/installerer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "BUN_PUBLIC_COMMIT_HASH=$(scripts/get-revision.sh) bun --hot src/index.ts",
    "start": "NODE_ENV=production BUN_PUBLIC_COMMIT_HASH=$(scripts/get-revision.sh) bun src/index.ts",
    "build": "bun run build.ts",
    "docs:generate": "bun scripts/generate-installer-contract.ts",
    "docs:check": "bun scripts/generate-installer-contract.ts --check",
    "test": "bun test",
    "test:update-snapshots": "UPDATE_INSTALLER_SNAPSHOTS=1 bun test",
    "lint": "oxlint --deny-warnings .",
    "format:check": "oxfmt --check .",
    "format": "oxfmt .",
    "typecheck": "tsc --noEmit",
    "deploy": "wrangler deploy",
    "preview": "wrangler dev"
  },
  "dependencies": {
    "bun-plugin-tailwind": "^0.1.2",
    "react": "^19",
    "react-dom": "^19",
    "tailwindcss": "^4.1.11"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@types/bun": "latest",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "license-checker": "25.0.1",
    "oxfmt": "0.57.0",
    "oxlint": "1.72.0",
    "typescript": "6.0.3",
    "wrangler": "4.106.0"
  }
}
