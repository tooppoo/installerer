{
  "schema": 1,
  "artifact_name": "binary-archives",
  "version_command": "scripts/release/print-version.sh",
  "build_script": "scripts/release/build-target.sh",
  "build_dist": "build/bin",
  "archive_prefix": "installerer",
  "targets": [
    {
      "id": "linux-x86_64",
      "runner": "ubuntu-24.04",
      "os": "Linux",
      "arch": "x86_64",
      "target": "bun-linux-x64-baseline",
      "archive": "tar.gz",
      "archive_files": [{ "path": "build/bin/installerer", "dest": "installerer" }]
    },
    {
      "id": "linux-arm64",
      "runner": "ubuntu-24.04-arm",
      "os": "Linux",
      "arch": "arm64",
      "target": "bun-linux-arm64",
      "archive": "tar.gz",
      "archive_files": [{ "path": "build/bin/installerer", "dest": "installerer" }]
    },
    {
      "id": "darwin-x86_64",
      "runner": "macos-15-intel",
      "os": "Darwin",
      "arch": "x86_64",
      "target": "bun-darwin-x64",
      "archive": "tar.gz",
      "archive_files": [{ "path": "build/bin/installerer", "dest": "installerer" }]
    },
    {
      "id": "darwin-arm64",
      "runner": "macos-15",
      "os": "Darwin",
      "arch": "arm64",
      "target": "bun-darwin-arm64",
      "archive": "tar.gz",
      "archive_files": [{ "path": "build/bin/installerer", "dest": "installerer" }]
    }
  ],
  "installer_smoke_test": {
    "installer_script": "install.sh",
    "command": "installerer",
    "target_ids": ["linux-x86_64", "linux-aarch64", "darwin-x86_64", "darwin-arm64"],
    "install_modes": ["latest", "pinned-latest-release"],
    "checks": [
      {
        "id": "help",
        "args": ["--help"]
      },
      {
        "id": "version",
        "args": ["--version"]
      }
    ]
  }
}
