{
  "owner": "tooppoo",
  "repo": "git-kura",
  "binary": {
    "name": "git-kura",
    "pathInArchive": "git-kura"
  },
  "archive": {
    "format": "zip",
    "nameTemplate": "{bin}_{version}_{target}.zip"
  },
  "checksum": {
    "fileName": "checksums.txt",
    "algorithm": "sha256"
  },
  "targets": [
    { "os": "linux", "arch": "x86_64" },
    { "os": "darwin", "arch": "aarch64" }
  ],
  "architectureLabels": {
    "x86_64": "universal",
    "aarch64": "universal"
  },
  "defaults": {
    "installDir": "/usr/local/bin"
  }
}
