{
  "description": "'.' and '..' match the architecture label character class but must be rejected explicitly.",
  "config": {
    "owner": "tooppoo",
    "repo": "rellog",
    "binary": {
      "name": "rellog",
      "pathInArchive": "bin/rellog"
    },
    "versionResolver": {
      "type": "release_version_file",
      "fileName": "VERSION"
    },
    "archive": {
      "format": "tar.gz",
      "nameTemplate": "{repo}_{version}_{target}.tar.gz"
    },
    "checksum": {
      "fileName": "checksums.txt",
      "algorithm": "sha256"
    },
    "targets": [{ "os": "linux", "arch": "x86_64" }],
    "architectureLabels": {
      "x86_64": "amd64",
      "aarch64": ".."
    }
  },
  "expectedErrors": [
    {
      "path": "$.architectureLabels.aarch64",
      "reasonIncludes": "Value is not a safe architecture label."
    }
  ]
}
