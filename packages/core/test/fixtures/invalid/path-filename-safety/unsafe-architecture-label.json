{
  "description": "architectureLabels values must be safe to embed in a Release asset filename.",
  "config": {
    "owner": "tooppoo",
    "repo": "rellog",
    "binary": {
      "name": "rellog",
      "pathInArchive": "bin/rellog"
    },
    "versionResolver": {
      "type": "release_version_file",
      "fileName": "VERSION"
    },
    "archive": {
      "format": "tar.gz",
      "nameTemplate": "{repo}_{version}_{target}.tar.gz"
    },
    "checksum": {
      "fileName": "checksums.txt",
      "algorithm": "sha256"
    },
    "targets": [{ "os": "linux", "arch": "x86_64" }],
    "architectureLabels": {
      "x86_64": "arm/64",
      "aarch64": "arm64"
    }
  },
  "expectedErrors": [
    {
      "path": "$.architectureLabels.x86_64",
      "reasonIncludes": "Value is not a safe architecture label."
    }
  ]
}
