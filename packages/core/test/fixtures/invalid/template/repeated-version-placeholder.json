{
  "description": "{version} may occur at most once in archive.nameTemplate.",
  "config": {
    "owner": "tooppoo",
    "repo": "rellog",
    "binary": {
      "name": "rellog",
      "pathInArchive": "bin/rellog"
    },
    "archive": {
      "format": "tar.gz",
      "nameTemplate": "{repo}_{version}_{os}_{version}.tar.gz"
    },
    "checksum": {
      "fileName": "checksums.txt",
      "algorithm": "sha256"
    },
    "targets": [{ "os": "linux", "arch": "x86_64" }]
  },
  "expectedErrors": [
    {
      "path": "$.archive.nameTemplate",
      "reasonIncludes": "{version} must occur zero or one times"
    }
  ]
}
