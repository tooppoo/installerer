{
  "description": "Placeholders outside the allowed set are rejected.",
  "config": {
    "owner": "tooppoo",
    "repo": "rellog",
    "binary": {
      "name": "rellog",
      "pathInArchive": "bin/rellog"
    },
    "archive": {
      "format": "tar.gz",
      "nameTemplate": "{asset}_{version}_{target}.tar.gz"
    },
    "checksum": {
      "fileName": "checksums.txt",
      "algorithm": "sha256"
    },
    "targets": [{ "os": "linux", "arch": "x86_64" }]
  },
  "expectedErrors": [
    {
      "path": "$.archive.nameTemplate",
      "reasonIncludes": "Unknown archive filename placeholder: {asset}"
    }
  ]
}
