{
  "description": "An archive name template with a stray closing brace is rejected.",
  "config": {
    "owner": "tooppoo",
    "repo": "rellog",
    "binary": {
      "name": "rellog",
      "pathInArchive": "bin/rellog"
    },
    "archive": {
      "format": "tar.gz",
      "nameTemplate": "repo}_{version}_{target}.tar.gz"
    },
    "checksum": {
      "fileName": "checksums.txt",
      "algorithm": "sha256"
    },
    "targets": [{ "os": "linux", "arch": "x86_64" }]
  },
  "expectedErrors": [
    { "path": "$.archive.nameTemplate", "reasonIncludes": "unmatched closing brace" }
  ]
}
