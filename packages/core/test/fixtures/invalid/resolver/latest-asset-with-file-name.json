{
  "description": "latest_asset does not read a VERSION asset, so fileName is rejected.",
  "config": {
    "owner": "tooppoo",
    "repo": "rellog",
    "binary": {
      "name": "rellog",
      "pathInArchive": "bin/rellog"
    },
    "versionResolver": {
      "type": "latest_asset",
      "fileName": "VERSION"
    },
    "archive": {
      "format": "tar.gz",
      "nameTemplate": "{repo}_{target}.tar.gz"
    },
    "checksum": {
      "fileName": "checksums.txt",
      "algorithm": "sha256"
    },
    "targets": [{ "os": "linux", "arch": "x86_64" }]
  },
  "expectedErrors": [
    {
      "path": "$.versionResolver.fileName",
      "reasonIncludes": "fileName is not supported for latest_asset."
    }
  ]
}
