{
  "description": "architectureLabels must be either a flat per-arch object or a per-OS object; mixing OS keys and architecture keys in one object is rejected.",
  "config": {
    "owner": "tooppoo",
    "repo": "rellog",
    "binary": {
      "name": "rellog",
      "pathInArchive": "bin/rellog"
    },
    "versionResolver": {
      "type": "release_version_file",
      "fileName": "VERSION"
    },
    "archive": {
      "format": "tar.gz",
      "nameTemplate": "{repo}_{version}_{target}.tar.gz"
    },
    "checksum": {
      "fileName": "checksums.txt",
      "algorithm": "sha256"
    },
    "targets": [{ "os": "linux", "arch": "x86_64" }],
    "architectureLabels": {
      "x86_64": "amd64",
      "linux": { "aarch64": "arm64" }
    }
  },
  "expectedErrors": [
    {
      "path": "$.architectureLabels.x86_64",
      "reasonIncludes": "Unknown field is not supported."
    }
  ]
}
