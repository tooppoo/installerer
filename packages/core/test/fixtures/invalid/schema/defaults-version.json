{
  "description": "defaults.version is rejected as an unknown field because version selection belongs to runtime --version dispatch.",
  "config": {
    "owner": "tooppoo",
    "repo": "rellog",
    "binary": {
      "name": "rellog",
      "pathInArchive": "bin/rellog"
    },
    "versionResolver": {
      "type": "release_version_file",
      "fileName": "VERSION"
    },
    "archive": {
      "format": "tar.gz",
      "nameTemplate": "{repo}_{version}_{target}.tar.gz"
    },
    "checksum": {
      "fileName": "checksums.txt",
      "algorithm": "sha256"
    },
    "targets": [{ "os": "linux", "arch": "x86_64" }],
    "defaults": {
      "version": "latest",
      "installDir": "$HOME/.local/bin"
    }
  },
  "expectedErrors": [
    { "path": "$.defaults.version", "reasonIncludes": "Unknown field is not supported." }
  ]
}
